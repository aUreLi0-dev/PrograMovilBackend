### ==========================================
### 3. DELEGADO - Publicar Anuncio en una Sección
### ==========================================
POST {{baseUrl}}/api/v1/delegate/announcements
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "section_id": 1,
  "title": "Entrega de Trabajo Final",
  "message": "Estimados, recuerden que la entrega del Trabajo Final es este domingo a las 11:59 PM sin prórroga."
}

### ==========================================
### 4. ANUNCIOS - Listar Anuncios de una Sección
### ==========================================
GET {{baseUrl}}/api/v1/sections/1/announcements
Authorization: Bearer {{token}}

### ==========================================
### 5. ESTADÍSTICAS - Obtener estadísticas dinámicas de una Sección
### ==========================================
GET {{baseUrl}}/api/v1/sections/1/statistics
Authorization: Bearer {{token}}

