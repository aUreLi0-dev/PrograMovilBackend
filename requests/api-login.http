### ==========================================
### 2. SIGN-OUT - Cerrar sesión
### ==========================================
GET {{baseUrl}}/api/sign-out
Authorization: Bearer {{token}}

### ==========================================
### 3. PERFIL - Obtener datos del usuario autenticado
### ==========================================
GET {{baseUrl}}/api/me
Authorization: Bearer {{token}}

### ==========================================
### 4. SETUP - Guardar carrera y especialidades
### ==========================================
PUT {{baseUrl}}/api/me/setup
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "career_id": 1,
  "especialidades": [1, 2],
  "current_level": 5
}

### ==========================================
### 5. ESPECIALIDADES - Actualizar solo especialidades
### ==========================================
PUT {{baseUrl}}/api/me/especialidades
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "especialidades": [2, 3]
}
